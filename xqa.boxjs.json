{
  "id": "antbu.app.sub",
  "name": "antbu应用订阅",
  "author": "@antbu",
  "repo": "https://github.com/antbu/quanx",
  "apps": [
    {
      "id": "xqa_ql",
      "name": "青龙cookie同步",
      "keys": [
        "@ql.url",
        "@ql.username",
        "@ql.password",
        "@ql.force_update",
        "@ql.token",
        "@ql.JD_WSCK",
        "@ql.JD_COOKIE",
        "@ql.jrycAccount",
        "@ql.gqcqCookie",
        "@ql.sfsyUrl",
        "@ql.meituanCookie",
        "@ql.elmCookie"
      ],
      "settings": [
        {
          "id": "@ql.url",
          "name": "青龙登陆的域名或IP:端口号",
          "val": "",
          "type": "text"
        },
        {
          "id": "@ql.username",
          "name": "账号",
          "val": "",
          "type": "text"
        },
        {
          "id": "@ql.password",
          "name": "密码",
          "val": "",
          "type": "text"
        },
        {
          "id": "@ql.force_update",
          "name": "强制更新",
          "val": false,
          "type": "boolean"
        }
      ],
      "icons": ["https://qn.whyour.cn/logo.png"],
      "author": "@antbu",
      "descs_html": [
        "应用client_id,client_secret请去 设置->应用 中添加相关参数"
      ]
    }
  ]
}
